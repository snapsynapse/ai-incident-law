{
  "name": "ai-incident-law",
  "version": "0.1.1",
  "mcpName": "io.github.snapsynapse/ai-incident-law",
  "description": "MCP server and static dataset for the AI Incident Law public-record corpus: AI-related litigation, regulatory action, tribunal records, and review-queue matters. Anchored to EveryAILaw obligations for cross-graph queries.",
  "homepage": "https://aiincidentlaw.org/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snapsynapse/ai-incident-law.git"
  },
  "bugs": {
    "url": "https://github.com/snapsynapse/ai-incident-law/issues"
  },
  "license": "MIT",
  "author": "PAICE.work PBC (https://paice.work/)",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-law",
    "ai-incident",
    "ai-litigation",
    "legal-research",
    "regulation",
    "compliance",
    "paice",
    "paice-legal-graph",
    "obligation-first",
    "everyailaw"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ai-incident-law": "scripts/mcp-server.js"
  },
  "main": "scripts/mcp-server.js",
  "files": [
    "scripts/mcp-server.js",
    "data/data.json",
    "api/v1/of/**/*.json",
    ".well-known/mcp.json",
    ".well-known/obligation-first-naming-profile.jsonld",
    "mcp.json",
    "agents.json",
    "README.md",
    "LICENSE",
    "DATA_LICENSE",
    "INTENT.md"
  ],
  "scripts": {
    "build:data": "node scripts/build-data.mjs",
    "build:of": "node scripts/build-obligation-first.mjs",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:of": "node scripts/validate-obligation-first.mjs",
    "eval:of": "node scripts/eval-obligation-first.mjs",
    "eval:url-policy": "node scripts/eval-url-policy-pipeline.mjs",
    "test:url-policy": "node scripts/test-url-policy.mjs",
    "test:mcp": "node --test tests/mcp-server.test.js",
    "test:discovery": "node --test tests/discovery.test.js",
    "check:of": "node scripts/check-of-version.mjs",
    "report:staleness": "node scripts/staleness-report.mjs",
    "build": "npm run build:data && npm run build:of && npm run validate:data",
    "check": "npm run validate:data && npm run test:url-policy && npm run eval:url-policy && npm run eval:of && npm run check:of && npm run test:mcp && npm run test:discovery",
    "serve": "python3 -m http.server 4173"
  }
}
